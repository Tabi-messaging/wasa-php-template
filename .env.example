# Your Tabi API key (create one at Dashboard -> Developer -> API Keys)
TABI_API_KEY=tk_your_api_key_here

# API base URL (default: https://api.c36.online/api/v1)
TABI_BASE_URL=https://api.c36.online/api/v1

# Default channel ID (Dashboard -> Channels -> copy the ID from the URL)
TABI_CHANNEL_ID=your-channel-id-here
